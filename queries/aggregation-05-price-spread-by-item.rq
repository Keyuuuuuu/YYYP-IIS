PREFIX yyyp: <http://example.org/yyyp/vocab#>

SELECT ?marketHashName
       (COUNT(?snapshot) AS ?validPlatformCount)
       (MIN(?price) AS ?minPriceCny)
       (MAX(?price) AS ?maxPriceCny)
       (ROUND(((MAX(?price) - MIN(?price)) / MIN(?price)) * 10000) / 100 AS ?spreadPct)
WHERE {
  ?item yyyp:marketHashName ?marketHashName ;
        yyyp:hasPriceSnapshot ?snapshot .
  ?snapshot yyyp:sellPriceCny ?price ;
            yyyp:hasValidSellPrice true .
}
GROUP BY ?marketHashName
HAVING (COUNT(?snapshot) >= 2 && MIN(?price) > 0)
ORDER BY DESC(?spreadPct)
LIMIT 30
