PREFIX yyyp: <http://example.org/yyyp/vocab#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

SELECT ?platformCode ?platformName
       (COUNT(?snapshot) AS ?observations)
       (SUM(IF(?valid, 1, 0)) AS ?validPrices)
       (ROUND((SUM(IF(?valid, 1, 0)) / COUNT(?snapshot)) * 10000) / 100 AS ?validCoveragePct)
WHERE {
  ?snapshot a yyyp:PriceSnapshot ;
            yyyp:observedOnPlatform ?platform ;
            yyyp:hasValidSellPrice ?valid .
  ?platform yyyp:platformCode ?platformCode ;
            rdfs:label ?platformName .
}
GROUP BY ?platformCode ?platformName
ORDER BY DESC(?validCoveragePct) ?platformCode
