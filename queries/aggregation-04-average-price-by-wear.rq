PREFIX yyyp: <http://example.org/yyyp/vocab#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

SELECT ?wear
       (COUNT(?snapshot) AS ?validObservations)
       (ROUND(AVG(?price) * 100) / 100 AS ?averageSellPriceCny)
WHERE {
  ?item yyyp:wearCondition/rdfs:label ?wear ;
        yyyp:hasPriceSnapshot ?snapshot .
  ?snapshot yyyp:sellPriceCny ?price ;
            yyyp:hasValidSellPrice true .
}
GROUP BY ?wear
ORDER BY DESC(?averageSellPriceCny)
