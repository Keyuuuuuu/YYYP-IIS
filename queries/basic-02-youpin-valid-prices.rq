PREFIX yyyp: <http://example.org/yyyp/vocab#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

SELECT ?marketHashName ?platformName ?price ?sellCount ?observedAt
WHERE {
  ?item yyyp:marketHashName ?marketHashName ;
        yyyp:hasPriceSnapshot ?snapshot .
  ?snapshot yyyp:observedOnPlatform <http://example.org/yyyp/resource/platform/YOUPIN> ;
            yyyp:observedOnPlatform/rdfs:label ?platformName ;
            yyyp:sellPriceCny ?price ;
            yyyp:sellCount ?sellCount ;
            yyyp:observedAt ?observedAt ;
            yyyp:hasValidSellPrice true .
}
ORDER BY DESC(?price)
LIMIT 30
